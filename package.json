{
  "name": "lang-property-poster",
  "version": "1.2.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "start": "next start -p 3030",
    "lint": "next lint",
    "electron": "concurrently -k -n NEXT,ELECTRON -c blue,magenta \"npm:dev\" \"wait-on http://localhost:3030 && electron .\"",
    "build:electron": "next build && node scripts/prepare-electron.mjs",
    "dist": "npm run build:electron && electron-builder --mac",
    "dist:dir": "npm run build:electron && electron-builder --mac --dir",
    "release": "npm run build:electron && electron-builder --mac --publish always"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "cheerio": "^1.0.0",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "next": "^15.0.3",
    "opentype.js": "^1.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.langtownandcountry.poster",
    "productName": "Lang Property Poster",
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "publish": {
      "provider": "github",
      "owner": "pbmediatools",
      "repo": "lang-poster-releases",
      "releaseType": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "msi",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "msi": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
