# Anthropic — required for caption generation
ANTHROPIC_API_KEY=sk-ant-...

# Sendible — get from https://app.sendible.com/?#/settings/api
# The Sendible REST API is documented internally; you may need to contact
# Sendible support to enable API access on your plan.
SENDIBLE_API_BASE=https://api.sendible.com/v1
SENDIBLE_API_KEY=
SENDIBLE_USERNAME=

# Sendible profile (service) IDs to post to.
# Find these via GET /v1/services with your API key.
# Comma-separated list: facebook page id, instagram, linkedin, x.
SENDIBLE_PROFILE_IDS=

# Canva Connect — requires Canva Enterprise + a registered integration
# https://www.canva.dev/docs/connect/
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
# Obtained via OAuth — see /api/canva/oauth route
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=

# The brand template ID for the "Lang To Let 2025" cover slide.
# Get this by opening the template in Canva and copying the ID from the URL,
# or list brand templates via GET /rest/v1/brand-templates.
CANVA_BRAND_TEMPLATE_ID=

# Default hashtags appended to every post
DEFAULT_HASHTAGS=#EstateAgents #PlymouthProperty
